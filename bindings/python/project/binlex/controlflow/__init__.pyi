from __future__ import annotations

from typing import Optional

from binlex import Architecture, Configuration
from binlex.embeddings import EmbeddingBackend
from binlex.genetics import Chromosome
from binlex.hashing import MinHash32, SHA256, SSDeep, TLSH
from binlex.lifters import Lifter, LifterBackend
from binlex.semantics import Semantic

class Reference:
    def __init__(self, location: int, address: int) -> None: ...
    def location(self) -> int: ...
    def address(self) -> int: ...
    def to_dict(self) -> dict[str, int]: ...

class Function:
    def __init__(self, address: int, cfg: Graph) -> None: ...
    def address(self) -> int: ...
    def architecture(self) -> Architecture: ...
    def chromosome(self) -> Chromosome | None: ...
    def cyclomatic_complexity(self) -> int: ...
    def average_instructions_per_block(self) -> float: ...
    def blocks(self) -> list[Block]: ...
    def bytes(self) -> bytes | None: ...
    def prologue(self) -> bool: ...
    def edges(self) -> int: ...
    def entropy(self) -> float | None: ...
    def number_of_instructions(self) -> int: ...
    def number_of_blocks(self) -> int: ...
    def callees(self) -> list[Function]: ...
    def callers(self) -> list[Function]: ...
    def callee_references(self) -> dict[int, int]: ...
    def caller_references(self) -> dict[int, int]: ...
    def processors(self) -> dict[str, object]: ...
    def processor(self, name: str) -> dict[str, object]: ...
    def embedding(
        self,
        backend: EmbeddingBackend | None = None,
        dimensions: int | None = None,
    ) -> list[float] | None: ...
    def lift(self, backend: LifterBackend | None = None) -> Lifter | None: ...
    def tlsh(self) -> TLSH | None: ...
    def sha256(self) -> SHA256 | None: ...
    def ssdeep(self) -> SSDeep | None: ...
    def minhash(self) -> MinHash32 | None: ...
    def markov(self) -> dict[int, float]: ...
    def size(self) -> int: ...
    def contiguous(self) -> bool: ...
    def end(self) -> int | None: ...
    def print(self) -> None: ...
    def to_dict(self) -> dict[str, object]: ...
    def json(self) -> str: ...

class BlockJsonDeserializer:
    """Deserialize a serialized block JSON payload into typed accessors."""

    def __init__(self, string: str, config: Configuration) -> None: ...
    def callee_references(self) -> list[Reference]: ...
    def architecture(self) -> Architecture: ...
    def bytes(self) -> bytes: ...
    def address(self) -> int: ...
    def minhash(self) -> MinHash32 | None: ...
    def tlsh(self) -> TLSH | None: ...
    def sha256(self) -> SHA256 | None: ...
    def ssdeep(self) -> str | None: ...
    def edges(self) -> int: ...
    def successor_references(self) -> list[Reference]: ...
    def predecessor_references(self) -> list[Reference]: ...
    def branches(self) -> set[int]: ...
    def conditional(self) -> bool: ...
    def entropy(self) -> float | None: ...
    def fallthrough(self) -> int | None: ...
    def size(self) -> int: ...
    def number_of_instructions(self) -> int: ...
    def chromosome(self) -> Chromosome | None: ...
    def to_dict(self) -> dict[str, object]: ...
    def json(self) -> str: ...
    def print(self) -> None: ...

