    def ssdeep(self) -> SSDeep: ...
    def minhash(self) -> MinHash32 | None: ...
    def end(self) -> int: ...
    def size(self) -> int: ...
    def print(self) -> None: ...
    def to_dict(self) -> dict[str, object]: ...
    def json(self) -> str: ...

class Instruction:
    def __init__(self, address: int, cfg: Graph) -> None: ...
    def address(self) -> int: ...
    def bytes(self) -> bytes: ...
    def mnemonic(self) -> str: ...
    def disassembly(self) -> str: ...
    def operands(self) -> list[Operand]: ...
    def chromosome(self) -> Chromosome: ...
    def successor_blocks(self) -> list[Block]: ...
    def successor_block_references(self) -> list[Reference]: ...
    def fallthrough(self) -> int | None: ...
    def branches(self) -> set[int]: ...
    def successors(self) -> set[int]: ...
    def has_indirect_target(self) -> bool: ...
    def is_conditional(self) -> bool: ...
    def callees(self) -> list[Function]: ...
    def callee_references(self) -> list[Reference]: ...
    def size(self) -> int: ...
    def processors(self) -> dict[str, object]: ...
    def processor(self, name: str) -> dict[str, object]: ...
    def embedding(
        self,
        backend: EmbeddingBackend | None = None,
        dimensions: int | None = None,
    ) -> list[float] | None: ...
    def lift(self, backend: LifterBackend | None = None) -> Lifter | None: ...
    def semantic(self) -> Semantic | None: ...
    def set_semantics(self, semantics: Semantic) -> Instruction: ...
    def to_dict(self) -> dict[str, object]: ...
    def json(self) -> str: ...
    def print(self) -> None: ...

