class OperandKind:
    Register: OperandKind
    Immediate: OperandKind
    Memory: OperandKind
    Float: OperandKind
    Special: OperandKind

class Operand:
    @classmethod
    def from_dict(cls, data: dict[str, object]) -> Operand: ...
    def kind(self) -> OperandKind: ...
    def is_register(self) -> bool: ...
    def is_immediate(self) -> bool: ...
    def is_memory(self) -> bool: ...
    def is_float(self) -> bool: ...
    def is_special(self) -> bool: ...
    def name(self) -> str | None: ...
    def value(self) -> int | float | None: ...
    def base(self) -> str | None: ...
    def index(self) -> str | None: ...
    def scale(self) -> int | None: ...
    def displacement(self) -> int | None: ...
    def segment(self) -> str | None: ...
    def space(self) -> str | None: ...
    def special_kind(self) -> str | None: ...
    def fields(self) -> dict[str, object] | None: ...
    def to_dict(self) -> dict[str, object]: ...
    def json(self) -> str: ...
    def print(self) -> None: ...

